# ─── Python cache ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ─── Test and tooling cache ───────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/

# ─── Local environment overrides (contains API keys — never commit) ───────────
.env

# ─── IDE and OS ───────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ─── Uploaded knowledge base files (user-added, not tracked) ─────────────────
data/*.md
data/*.txt
!data/knowledge_base.md

# ─── Experiment outputs and paper drafts ─────────────────────────────────────
reports/

# ─── Model weights and large files ───────────────────────────────────────────
*.pth
*.pt
*.h5
*.pkl
*.bin

# ─── Streamlit runtime ───────────────────────────────────────────────────────
.streamlit/secrets.toml
